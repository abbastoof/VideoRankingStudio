# =============================================================================
# VideoRankingStudio — environment configuration
# Copy to `.env` for local development. NEVER commit the populated file.
# Each section corresponds to a subsystem; required vars are marked [REQUIRED].
# =============================================================================

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
NODE_ENV=development                      # development | test | staging | production
LOG_LEVEL=debug                           # debug | info | warn | error
TZ=UTC

# Service URLs (used by frontend + service-to-service calls)
WEB_URL=http://localhost:3000             # public-facing web app
API_URL=http://localhost:4000             # backend API
WORKERS_URL=http://localhost:5000         # internal workers admin (FastAPI)
PUBLIC_CDN_URL=http://localhost:9000/vrs-public  # static asset CDN (MinIO locally)

# -----------------------------------------------------------------------------
# Database (PostgreSQL) [REQUIRED]
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://vrs:vrs@localhost:5432/vrs?schema=public
DATABASE_URL_SHADOW=postgresql://vrs:vrs@localhost:5432/vrs_shadow?schema=public
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_STATEMENT_TIMEOUT_MS=30000

# -----------------------------------------------------------------------------
# Cache & queue (Redis) [REQUIRED]
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_QUEUE_URL=redis://localhost:6379/1

# -----------------------------------------------------------------------------
# Message broker (RabbitMQ / SQS-compatible)
# -----------------------------------------------------------------------------
BROKER_URL=amqp://vrs:vrs@localhost:5672//
BROKER_RESULT_BACKEND=redis://localhost:6379/2

# -----------------------------------------------------------------------------
# Object storage (S3 / MinIO) [REQUIRED]
# -----------------------------------------------------------------------------
S3_ENDPOINT=http://localhost:9000          # leave empty in production for real AWS
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true                  # required for MinIO
S3_BUCKET_UPLOADS=vrs-uploads             # user uploads (videos, audio, images)
S3_BUCKET_GENERATED=vrs-generated         # AI-generated assets
S3_BUCKET_EXPORTS=vrs-exports             # final rendered videos
S3_BUCKET_PUBLIC=vrs-public               # publicly-readable assets (thumbnails)
S3_PRESIGNED_URL_TTL_SECONDS=3600

# -----------------------------------------------------------------------------
# Authentication & sessions [REQUIRED in production]
# -----------------------------------------------------------------------------
JWT_ACCESS_SECRET=change-me-min-32-chars-long-secret-value
JWT_REFRESH_SECRET=change-me-different-min-32-chars-long-secret
JWT_ACCESS_TTL_SECONDS=900                # 15 minutes
JWT_REFRESH_TTL_SECONDS=2592000           # 30 days
OTP_TTL_SECONDS=600                       # 10 minutes
OTP_LENGTH=6
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60
SESSION_COOKIE_NAME=vrs_session
SESSION_COOKIE_DOMAIN=localhost
SESSION_COOKIE_SECURE=false               # true in production (requires HTTPS)
SESSION_COOKIE_SAMESITE=lax

# OAuth (optional)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URL=http://localhost:4000/auth/google/callback

# -----------------------------------------------------------------------------
# Email delivery (SendGrid / SES / SMTP)
# -----------------------------------------------------------------------------
EMAIL_PROVIDER=smtp                       # smtp | sendgrid | ses
EMAIL_FROM_ADDRESS=noreply@videorankingstudio.local
EMAIL_FROM_NAME=VideoRankingStudio
EMAIL_REPLY_TO=support@videorankingstudio.local
# Ops inbox for public /contact submissions. Falls back to EMAIL_FROM_ADDRESS.
CONTACT_INBOX_EMAIL=

# SMTP (Mailhog for local)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

# SendGrid (production)
SENDGRID_API_KEY=

# AWS SES (alternative)
SES_REGION=us-east-1
SES_ACCESS_KEY_ID=
SES_SECRET_ACCESS_KEY=

# -----------------------------------------------------------------------------
# Stripe (billing) [REQUIRED for billing flows]
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_FREE=price_free_placeholder
STRIPE_PRICE_CREATOR_MONTHLY=price_creator_m_placeholder
STRIPE_PRICE_CREATOR_ANNUAL=price_creator_y_placeholder
STRIPE_PRICE_BUSINESS_MONTHLY=price_business_m_placeholder
STRIPE_PRICE_BUSINESS_ANNUAL=price_business_y_placeholder
STRIPE_CUSTOMER_PORTAL_RETURN_URL=http://localhost:3000/settings/billing

# -----------------------------------------------------------------------------
# AI providers — configure the ones you use; leave others blank
# -----------------------------------------------------------------------------

# Large language models (script generation, ideation, rewrite)
LLM_PROVIDER=anthropic                    # anthropic | openai | local
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_ORG_ID=

# Text-to-speech / voice cloning
TTS_PROVIDER=elevenlabs                   # elevenlabs | azure | polly | coqui
ELEVENLABS_API_KEY=
ELEVENLABS_DEFAULT_VOICE_ID=
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
AWS_POLLY_ACCESS_KEY_ID=
AWS_POLLY_SECRET_ACCESS_KEY=
AWS_POLLY_REGION=us-east-1

# Speech-to-text (transcription / captions)
STT_PROVIDER=openai_whisper               # openai_whisper | local_whisper | google | deepgram
DEEPGRAM_API_KEY=
GOOGLE_STT_CREDENTIALS_JSON=
LOCAL_WHISPER_MODEL=base                  # tiny|base|small|medium|large-v3
LOCAL_WHISPER_DEVICE=cpu                  # cpu|cuda

# Image generation (thumbnails, b-roll)
IMAGE_PROVIDER=stability                  # stability | openai | replicate | local_sd
STABILITY_API_KEY=
REPLICATE_API_TOKEN=
LOCAL_SD_MODEL=stabilityai/stable-diffusion-xl-base-1.0
LOCAL_SD_DEVICE=cuda

# Video generation (text-to-video)
VIDEO_GEN_PROVIDER=runway                 # runway | pika | replicate | disabled
RUNWAY_API_KEY=
PIKA_API_KEY=

# -----------------------------------------------------------------------------
# Social import (YouTube / TikTok / Instagram)
# -----------------------------------------------------------------------------
YOUTUBE_API_KEY=
# Publish-target OAuth credentials. Required if you enable YouTube upload.
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
YT_DLP_BINARY=yt-dlp                      # path to yt-dlp executable
YT_DLP_PROXY=                              # optional proxy for region-locked content

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=vrs
PROMETHEUS_METRICS_PORT=9464

# -----------------------------------------------------------------------------
# Feature flags (defaults; can also be driven by a flag service)
# -----------------------------------------------------------------------------
FEATURE_VOICE_CLONING=true
FEATURE_AI_VIDEO_GEN=false
FEATURE_TEAM_ACCOUNTS=false
FEATURE_PUBLISH_TO_YOUTUBE=false
FEATURE_PUBLISH_TO_TIKTOK=false

# -----------------------------------------------------------------------------
# Limits & quotas (used by middleware; can be overridden per-plan in DB)
# -----------------------------------------------------------------------------
RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_API_PER_MINUTE=120
RATE_LIMIT_AI_PER_MINUTE=20
UPLOAD_MAX_BYTES=5368709120               # 5 GiB
EXPORT_MAX_DURATION_SECONDS=600
VOICEOVER_MAX_CHARS_FREE=1500
VOICEOVER_MAX_CHARS_CREATOR=50000
VOICEOVER_MAX_CHARS_BUSINESS=200000

# -----------------------------------------------------------------------------
# Internal service authentication (workers <-> api)
# -----------------------------------------------------------------------------
INTERNAL_SERVICE_TOKEN=change-me-internal-token

# -----------------------------------------------------------------------------
# Frontend-only (Next.js public env, must be prefixed NEXT_PUBLIC_)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME=VideoRankingStudio
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WEBSOCKET_URL=ws://localhost:4000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_SUPPORT_EMAIL=support@videorankingstudio.local
