{
  "title": "VRS · Worker throughput",
  "uid": "vrs-worker-throughput",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "tags": ["vrs", "workers"],
  "timezone": "browser",
  "panels": [
    {
      "type": "stat",
      "title": "Jobs enqueued / min",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(rate(vrs_api_ai_jobs_enqueued_total[5m])) * 60",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Backlog (queued + running + retrying)",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(celery_worker_up)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Jobs enqueued by kind",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "sum by (kind) (rate(vrs_api_ai_jobs_enqueued_total[1m]))",
          "legendFormat": "{{kind}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Celery queue length by queue",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "celery_queue_length",
          "legendFormat": "{{queue_name}}",
          "refId": "A"
        }
      ]
    }
  ]
}
